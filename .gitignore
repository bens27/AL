## --- AL gitignore ---
## Ignores generated binary files and 
## temporary files from Visual Studio and Visual Studio code

# Binary files
.alpackages/
*.app

# Temp files
.vs/

# User-specific IDE config (shared .vscode/extensions.json and settings.json are tracked)
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-workspace

# Others
~$*
*~